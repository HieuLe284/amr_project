<?xml version="1.0"?>
<robot name="my_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Thông số kỹ thuật của robot -->
  <!-- 
    Body: 205 x 138 x 68 mm
    Wheel: 58 x 28 mm
    Chất liệu: Nhựa ABS
  -->
  
  <!-- Tham số vật liệu -->
  <xacro:property name="density" value="1050"/> <!-- kg/m3 -->
  <xacro:property name="pi" value="3.141592653589793"/>

  <!-- Tham số khung chassis -->
  <xacro:property name="chassis_length" value="0.205"/>
  <xacro:property name="chassis_width"  value="0.138"/>
  <xacro:property name="chassis_height" value="0.068"/>
  <xacro:property name="chassis_volume" value="${chassis_length * chassis_width * chassis_height}"/>
  <xacro:property name="chassis_mass"   value="${chassis_volume * density}"/>

  <!-- Tham số bánh xe -->
  <xacro:property name="wheel_diameter" value="0.058"/>
  <xacro:property name="wheel_radius" value="${wheel_diameter / 2}"/>
  <xacro:property name="wheel_length" value="0.028"/>
  <xacro:property name="wheel_volume" value="${wheel_radius*wheel_radius * pi * wheel_length}"/>
  <xacro:property name="wheel_mass"   value="${wheel_volume * density}"/>

  <!-- Lidar link -->
  <link name="lidar_link">
   <visual>
     <geometry>
       <cylinder radius="0.06" length="0.03"/>
     </geometry>
     <material name="red"/>
   </visual>
   <collision>
     <geometry>
       <cylinder radius="0.06" length="0.03"/>
     </geometry>
   </collision>
   <inertial>
     <mass value="0.1"/>
     <inertia ixx="0.001" iyy="0.001" izz="0.001" ixy="0.0" ixz="0.0" iyz="0.0"/>
   </inertial>
 </link>

  <!-- Vị trí bánh xe so với khung chassis -->
  <xacro:property name="margin_x" value="0.02"/>
  <xacro:property name="margin_y" value="0.02"/>
  <xacro:property name="margin_z" value="0.01"/>

  <xacro:property name="x_position" value="${chassis_length / 2 - margin_x}"/>
  <xacro:property name="y_position"  value="${chassis_width / 2 + margin_y}"/>
  <xacro:property name="z_position" value="${chassis_height / 2 - margin_z}"/>

  <!-- Inertia của hình hộp -->
  <xacro:macro name="box_inertia" params="m x y z">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${m}"/>
      <inertia
        ixx="${m/12.0*(y*y+z*z)}" ixy="0.0" ixz="0.0"
        iyy="${m/12.0*(x*x+z*z)}" iyz="0.0"
        izz="${m/12.0*(x*x+y*y)}"/>
    </inertial>
  </xacro:macro>

  <!-- Inertia của hình trụ -->
  <xacro:macro name="cylinder_inertia" params="m r h">
    <inertial>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      <mass value="${m}"/>
      <inertia
        ixx="${m/12.0*(3*r*r+h*h)}" ixy="0.0" ixz="0.0"
        iyy="${m/12.0*(3*r*r+h*h)}" iyz="0.0"
        izz="${m/2.0*r*r}"/>
    </inertial>
  </xacro:macro>

  <!-- Xử lý bánh xe -->
  <xacro:macro name="wheel" params="prefix x_pos y_pos z_pos y_reflect">
    <link name="${prefix}_wheel">
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_length}"/>
        </geometry>
        <material name="white"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_length}"/>
        </geometry>
      </collision>
      <xacro:cylinder_inertia m="${wheel_mass}" r="${wheel_radius}" h="${wheel_length}"/>
    </link>

    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="chassis"/>
      <child  link="${prefix}_wheel"/>
      <origin xyz="${x_pos} ${y_pos} ${z_pos}" rpy="0 0 ${(1 - y_reflect) * pi / 2}"/>
      <axis xyz="0 ${y_reflect} 0"/>
      <dynamics damping="0.05" friction="0.05"/>
    </joint>
  </xacro:macro>

  <!-- Màu sắc vật liệu -->
  <material name="black">
    <color rgba="0 0 0 1"/>
  </material>

  <!-- <material name="green">
    <color rgba="0 0.8 0 1"/>
  </material> -->

  <material name="white">
    <color rgba="1 1 1 1"/>
  </material>

  <!-- Link gốc của robot -->
 <material name="red">	122	<!-- Link gốc của robot -->
<color rgba="1 0 0 1"/>	123	<link name="base_link"/>
</material>		
		
<link name="base_link">		
<inertial>		
<mass value="0.001"/>		
<inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>		
</inertial>		
	</link>

  <link name="chassis">
    <visual>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="${chassis_mass}"
                       x="${chassis_length}"
                       y="${chassis_width}"
                       z="${chassis_height}"/>
  </link>

  <joint name="chassis_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="chassis"/>
    <origin xyz="0 0 ${wheel_radius + z_position}" rpy="0 0 0"/>
  </joint>

  <!-- Vị trí của bánh xe so với base - link -->
  <xacro:wheel prefix="front_right" x_pos="${x_position}"  y_pos="-${y_position}" z_pos="-${z_position}" y_reflect="-1"/>
  <xacro:wheel prefix="front_left"  x_pos="${x_position}"  y_pos="${y_position}"  z_pos="-${z_position}" y_reflect="1"/>
  <xacro:wheel prefix="rear_right"  x_pos="-${x_position}" y_pos="-${y_position}" z_pos="-${z_position}" y_reflect="-1"/>
  <xacro:wheel prefix="rear_left"   x_pos="-${x_position}" y_pos="${y_position}"  z_pos="-${z_position}" y_reflect="1"/>

 <!-- Joint between base_link and lidar_link -->
 <joint name="lidar_joint" type="fixed">
   <parent link="base_link"/>
   <child link="lidar_link"/>
   <origin xyz="0 0 ${chassis_height + 0.045}" rpy="0 0 0"/>
   <!-- <origin xyz="0 0 ${chassis_height + 0.045}" rpy="0 0 3.14159"/> -->
 </joint>


 <!-- Lidar sensor -->
 <gazebo reference="lidar_link">
   <sensor type="ray" name="lidar">
   <pose>0 0 0 0 0 0</pose>
     <!-- <pose>0 0 0 0 0 3.14159</pose> -->
     <visualize>true</visualize>
     <ray>
       <scan>
         <horizontal>
           <samples>360</samples>
           <resolution>1</resolution>
           <min_angle>-3.14159</min_angle>
           <max_angle>3.14159</max_angle>
         </horizontal>
       </scan>
       <range>
         <min>0.1</min>
         <max>10.0</max>
       </range>
       <noise>
         <type>gaussian</type>
         <mean>0.0</mean>
         <stddev>0.01</stddev>
       </noise>
     </ray>
      <plugin name="gazebo_ros_laser" filename="libgazebo_ros_ray_sensor.so">
        <ros>
          <remapping>~/out:=agv_scan</remapping>
        </ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <update_rate>10.0</update_rate>
      </plugin>
   </sensor>
 </gazebo>

  <xacro:include filename="gazebo.xacro"/>

</robot>